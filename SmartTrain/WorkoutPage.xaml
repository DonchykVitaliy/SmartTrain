<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SmartTrain.WorkoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmartTrain"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">
        <TextBlock x:Name="PageTitle" Text="Мої тренування" FontSize="28" FontWeight="Bold" VerticalAlignment="Top"/>

        <GridView x:Name="ExercisesGridView" Margin="0,50,0,0" SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:Exercise">
                    <Border Width="260" Height="220" CornerRadius="12" 
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
            BorderThickness="1" Padding="15" Margin="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="18" FontWeight="Bold" 
                           TextWrapping="Wrap" Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Spacing="4">
                                    <Button x:Name="DeleteBtn" Click="DeleteBtn_Click" 
                            Background="Transparent" BorderBrush="Transparent" Padding="4"
                            ToolTipService.ToolTip="Видалити вправу">
                                        <SymbolIcon Symbol="Delete" Foreground="#D15A5A" />
                                    </Button>

                                    <SymbolIcon Symbol="Important" Foreground="Gray" Margin="0,6,0,0">
                                        <ToolTipService.ToolTip>
                                            <TextBlock Text="{Binding TooltipInfo}"/>
                                        </ToolTipService.ToolTip>
                                    </SymbolIcon>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding Description}" Grid.Row="1" TextWrapping="Wrap" 
                       TextTrimming="CharacterEllipsis" Foreground="Gray" Margin="0,15,0,0"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <SymbolIcon Symbol="Clock" Foreground="{ThemeResource SystemAccentColor}"/>
                                    <TextBlock Text="{Binding EstimatedTimeMinutes}"/>
                                    <TextBlock Text="хв"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <SymbolIcon Symbol="OutlineStar" Foreground="{ThemeResource SystemAccentColor}"/>
                                    <TextBlock Text="{Binding DifficultyTranslated}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>


            <GridView.Footer>
                <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40" Width="400">
                    <Button x:Name="ClearPlanBtn" 
                    Click="ClearPlanBtn_Click"
                    HorizontalAlignment="Stretch"
                    Padding="15"
                    CornerRadius="8"
                    Background="Transparent"
                    BorderBrush="#D15A5A"
                    BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Delete" Foreground="#D15A5A"/>
                            <TextBlock Text="Очистити весь план тренувань" 
                               Foreground="#D15A5A" 
                               FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Ця дія видалить всі вправи з вашого поточного списку" 
                       HorizontalAlignment="Center" 
                       Foreground="Gray" 
                       FontSize="12" 
                       Margin="0,10,0,0"/>
                </StackPanel>
            </GridView.Footer>
        </GridView>

        <ContentDialog x:Name="ConfirmDeleteDialog"
               Title="Видалити весь план?"
               Content="Ви впевнені, що хочете очистити весь список вправ? Цю дію неможливо скасувати."
               PrimaryButtonText="Так, очистити"
               CloseButtonText="Скасувати"
               DefaultButton="Close"
               PrimaryButtonClick="ConfirmDeleteDialog_PrimaryButtonClick">
        </ContentDialog>
    </Grid>
</Page>
