<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SmartTrain.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmartTrain"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SmartTrain">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <StackPanel x:Name="RegistrationArea" 
            Visibility="Collapsed" 
            Spacing="15" 
            Width="400" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Canvas.ZIndex="10">

            <TextBlock Text="Створення профілю Smart Train" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBox x:Name="RegName" Header="Ваше ім'я" PlaceholderText="Введіть ім'я..."/>
            <NumberBox x:Name="RegAge" Header="Вік" Value="20" SpinButtonPlacementMode="Inline"/>
            <NumberBox x:Name="RegWeight" Header="Вага (кг)" Value="70" SpinButtonPlacementMode="Inline"/>
            <NumberBox x:Name="RegHeight" Header="Зріст (см)" Value="175" SpinButtonPlacementMode="Inline"/>

            <ComboBox x:Name="RegLevel" Header="Фізична підготовка" SelectedIndex="0" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Початківець"/>
                <ComboBoxItem Content="Середній"/>
                <ComboBoxItem Content="Професіонал"/>
            </ComboBox>

            <Button Content="Створити профіль" 
                Click="SaveProfile_Click" 
                HorizontalAlignment="Stretch" 
                Style="{StaticResource AccentButtonStyle}" 
                Margin="0,15,0,0"
                Padding="10"/>
        </StackPanel>

        
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,50,0" Canvas.ZIndex="1" Spacing="10">
            <Button x:Name="ChangeGoalButton" 
                    Visibility="Collapsed"
                    Click="ChangeGoalButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Edit"/>
                    <TextBlock Text="Змінити ціль"/>
                </StackPanel>
            </Button>

            <Button x:Name="BuildPlanButton" 
                    Click="BuildPlanButton_Click"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Play"/>
                    <TextBlock Text="Побудувати план"/>
                </StackPanel>
            </Button>
        </StackPanel>


        <TeachingTip x:Name="PlanSuccessTip"
             Title="Успіх!"
             Subtitle="План успішно сформовано та збережено."
             PreferredPlacement="BottomRight"
             Target="{Binding ElementName=BuildPlanButton}">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Accept" />
            </TeachingTip.IconSource>
        </TeachingTip>

        

        <NavigationView x:Name="MainNav" 
                        PaneTitle="Smart Train Menu"
                        IsSettingsVisible="True"
                        Background="Transparent"
                        SelectionChanged="MainNav_SelectionChanged">


            <NavigationView.MenuItems>
                <NavigationViewItem Content="Головна сторінка" Icon="Home" Tag="HomePage"/>
                <NavigationViewItem Content="Тренування" Icon="Bullets" Tag="WorkoutPage"/>
                <NavigationViewItem Content="Ціль" Icon="CalendarWeek" Tag="GoalPage"/>
                <NavigationViewItem Content="Статистика" Icon="FourBars" Tag="StatsPage"/>
                <NavigationViewItem Content="Досягнення" Icon="Favorite" Tag="AchievementsPage"/>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <NavigationViewItem x:Name="ProfileItem" Content="Мій Профіль" Icon="Contact" Tapped="ProfileItem_Tapped"/>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" Margin="24"/>
        </NavigationView>

        <ContentDialog x:Name="EditProfileDialog"
               Title="Редагування профілю"
               PrimaryButtonText="Зберегти"
               SecondaryButtonText="Скасувати"
               CloseButtonText="Видалити профіль"
               DefaultButton="Primary"
               PrimaryButtonClick="EditProfileDialog_PrimaryButtonClick"
               CloseButtonClick="EditProfileDialog_CloseButtonClick">
            <StackPanel Spacing="10" Width="300">
                <TextBox x:Name="EditName" Header="Ім'я"/>
                <NumberBox x:Name="EditAge" Header="Вік" SpinButtonPlacementMode="Inline"/>
                <NumberBox x:Name="EditWeight" Header="Вага (кг)" SpinButtonPlacementMode="Inline"/>
                <NumberBox x:Name="EditHeight" Header="Зріст (см)" SpinButtonPlacementMode="Inline"/>
                <ComboBox x:Name="EditLevel" Header="Рівень підготовки" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Початківець"/>
                    <ComboBoxItem Content="Середній"/>
                    <ComboBoxItem Content="Професіонал"/>
                </ComboBox>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="BuildPlanDialog"
               Title="Параметри нового плану"
               PrimaryButtonText="Сформувати"
               CloseButtonText="Скасувати"
               PrimaryButtonClick="BuildPlanDialog_PrimaryButtonClick">
            <StackPanel Spacing="15" Width="300">
                <ComboBox x:Name="SelectLocation" Header="Де ви будете тренуватися?" HorizontalAlignment="Stretch" SelectedIndex="0">
                    <ComboBoxItem Content="Вдома"/>
                    <ComboBoxItem Content="Спортзал"/>
                </ComboBox>

                <ComboBox x:Name="SelectDifficulty" Header="Бажана складність" HorizontalAlignment="Stretch" SelectedIndex="0">
                    <ComboBoxItem Content="Легко"/>
                    <ComboBoxItem Content="Середньо"/>
                    <ComboBoxItem Content="Важко"/>
                </ComboBox>

                <TextBlock Text="Програма також врахує ваші параметри: вагу, зріст та вік." 
                   TextWrapping="Wrap" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </ContentDialog>


        <ContentDialog x:Name="AchievementPopupDialog"
                       PrimaryButtonText="Отримати"
                       Style="{StaticResource DefaultContentDialogStyle}"
                       PrimaryButtonClick="AchievementPopupDialog_PrimaryButtonClick">

            <StackPanel Width="500" MinHeight="250" Spacing="20" HorizontalAlignment="Center">

                <TextBlock x:Name="AchievementTitleText" 
                           Text="🏆 Досягнення розблоковано!" 
                           FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>

                <TextBlock Text="🏆" FontSize="72" HorizontalAlignment="Center"/>

                <StackPanel Spacing="5" HorizontalAlignment="Center">
                    <TextBlock x:Name="AchievementSubtitleText" 
                               Text="Назва досягнення" 
                               FontSize="18" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}"/>

                    <TextBlock x:Name="AchievementDescText" 
                               Text="Опис того, що ви зробили. Дуже детальний та мотивуючий опис." 
                               TextWrapping="Wrap" 
                               FontSize="14" 
                               Foreground="Gray" 
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ContentDialog>
    </Grid>
</Window>